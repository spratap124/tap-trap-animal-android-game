# Copy to keystore.properties in the project root (gitignored). Gradle also accepts key.properties
# or app/keystore.properties with the same keys.
#
# If you already set signing in Android Studio: that only applies when you use Build > Generate Signed
# Bundle/APK from the IDE. For ./gradlew bundleRelease and bumpAndBundleRelease, copy the same values
# here — keystore path (storeFile), key alias, and both passwords. Paths can be absolute or relative
# to the project root.
#
# Create a new keystore once, e.g.:
#   keytool -genkey -v -keystore app/upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload

storeFile=app/upload-keystore.jks
storePassword=your-store-password
keyAlias=upload
keyPassword=your-key-password
