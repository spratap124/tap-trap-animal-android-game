<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Rainbow gradient ring (the full card size) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF4444"
                android:centerColor="#FFD700"
                android:endColor="#A855F7"
                android:angle="0"
                android:type="linear" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <!-- Dark card interior inset by 2.5dp on all sides to show the rainbow ring -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1e1e1e"
                android:endColor="#0f0f0f"
                android:angle="270" />
            <corners android:radius="16dp" />
        </shape>
    </item>

</layer-list>
