<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp"
    android:background="@drawable/shop_panel_bg">

    <!-- Icon -->
    <TextView
        android:id="@+id/gameOverIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💀"
        android:textSize="52sp" />

    <!-- Title -->
    <TextView
        android:id="@+id/gameOverTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GAME OVER"
        android:textColor="#FF4444"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginTop="8dp" />

    <!-- Near-miss subtitle (shown conditionally) -->
    <TextView
        android:id="@+id/gameOverSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="So close! 😱"
        android:textColor="#FFD700"
        android:textSize="15sp"
        android:layout_marginTop="4dp"
        android:visibility="gone" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="16dp" />

    <!-- Stats row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ Score"
                android:textColor="#aaaaaa"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/gameOverScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#ffffff"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏁 Level"
                android:textColor="#aaaaaa"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/gameOverLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="#ffffff"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 Combo"
                android:textColor="#aaaaaa"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/gameOverCombo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="x1"
                android:textColor="#ffffff"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="16dp" />

    <!-- Continue via Ad button (primary CTA) -->
    <Button
        android:id="@+id/btnContinueAd"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📺  Continue Streak"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/btn_watch_ad_bg"
        android:stateListAnimator="@null" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Watch a short ad to keep your score &amp; combo"
        android:textColor="#888888"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginTop="4dp" />

    <!-- Restart button (secondary) -->
    <Button
        android:id="@+id/btnRestart"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="❌  Start Fresh"
        android:textColor="#cccccc"
        android:textSize="14sp"
        android:background="@drawable/btn_danger_bg"
        android:stateListAnimator="@null"
        android:layout_marginTop="10dp" />

</LinearLayout>
