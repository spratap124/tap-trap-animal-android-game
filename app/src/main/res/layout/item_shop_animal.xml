<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="12dp"
    android:layout_margin="6dp"
    android:background="@drawable/shop_item_bg">

    <TextView
        android:id="@+id/shopItemEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🐭"
        android:textSize="38sp" />

    <TextView
        android:id="@+id/shopItemName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rat"
        android:textColor="#ffffff"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/shopItemPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 🪙"
        android:textColor="#aaaaaa"
        android:textSize="12sp"
        android:layout_marginTop="3dp" />

    <!-- Coin buy button -->
    <Button
        android:id="@+id/shopBuyBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🪙 BUY"
        android:textColor="#ffffff"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="@drawable/btn_shop_buy_bg"
        android:stateListAnimator="@null"
        android:layout_marginTop="7dp"
        android:paddingVertical="7dp"
        android:lines="2"
        android:ellipsize="none" />

    <!-- Watch Ad unlock button -->
    <Button
        android:id="@+id/shopWatchAdBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📺 Watch Ad"
        android:textColor="#ffffff"
        android:textSize="12sp"
        android:textStyle="bold"
        android:background="@drawable/btn_watch_ad_bg"
        android:stateListAnimator="@null"
        android:layout_marginTop="5dp"
        android:paddingVertical="7dp" />

</LinearLayout>
