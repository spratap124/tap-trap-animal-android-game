<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/shop_panel_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/shop_header_bg">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚙️ Settings"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <Button
            android:id="@+id/settingsCloseBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="✕"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:background="@drawable/close_btn_bg"
            android:stateListAnimator="@null"
            android:padding="0dp" />
    </LinearLayout>

    <!-- Toggle rows -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Sound toggle -->
        <LinearLayout
            android:id="@+id/soundRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:background="@drawable/settings_row_bg"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊"
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sound Effects"
                    android:textColor="#ffffff"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap, trap &amp; game sounds"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/soundToggle"
                android:layout_width="52dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="ON"
                android:textColor="#ffffff"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/settings_toggle_on" />
        </LinearLayout>

        <!-- Announce toggle -->
        <LinearLayout
            android:id="@+id/announceRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:background="@drawable/settings_row_bg"
            android:layout_marginTop="10dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗣️"
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Animal Announce"
                    android:textColor="#ffffff"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speak animal name on switch"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/announceToggle"
                android:layout_width="52dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="ON"
                android:textColor="#ffffff"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/settings_toggle_on" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginVertical="14dp" />

        <!-- How to Play button -->
        <Button
            android:id="@+id/settingsHowToPlayBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="❓  How to Play"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/btn_primary_bg"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>
