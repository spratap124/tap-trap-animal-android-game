<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TapTrapAnimal" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/bgDark</item>
        <item name="android:statusBarColor">#111111</item>
        <item name="android:navigationBarColor">#111111</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- ── Instruction card styles ───────────────────────────────────── -->
    <style name="InstrCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">top</item>
        <item name="android:background">@drawable/hud_box_bg</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="InstrIcon">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">28sp</item>
        <item name="android:layout_marginEnd">12dp</item>
    </style>

    <style name="InstrTextCol">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="InstrTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#ffffff</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">3dp</item>
    </style>

    <style name="InstrBody">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#cccccc</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <style name="ShopDialogTheme" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.85</item>
    </style>

</resources>
