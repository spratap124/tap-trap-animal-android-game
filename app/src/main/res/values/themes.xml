<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TapTrapAnimal" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/bgDark</item>
        <item name="android:statusBarColor">#111111</item>
        <item name="android:navigationBarColor">#111111</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="ShopDialogTheme" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.85</item>
    </style>

</resources>
